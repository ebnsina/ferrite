# Copy to `.env` and adjust as needed. All vars are prefixed FERRITE_.
# Defaults already match the bundled docker-compose stack.

# --- API ---
FERRITE_BIND_ADDR=0.0.0.0:8080
FERRITE_PUBLIC_URL=http://localhost:8080

# --- Postgres ---
FERRITE_DATABASE_URL=postgres://ferrite:ferrite@localhost:5432/ferrite

# --- Redis (job queue) ---
FERRITE_REDIS_URL=redis://localhost:6379
FERRITE_QUEUE_GROUP=transcoders
FERRITE_MAX_INFLIGHT_PER_TENANT=4
FERRITE_RECLAIM_MIN_IDLE_SECS=30
FERRITE_RUN_SCHEDULER=true

# --- Object storage (MinIO in dev) ---
FERRITE_S3_BUCKET=ferrite
FERRITE_S3_ENDPOINT_URL=http://localhost:9000
FERRITE_S3_FORCE_PATH_STYLE=true

# AWS SDK credentials (MinIO root creds in dev)
AWS_ACCESS_KEY_ID=ferrite
AWS_SECRET_ACCESS_KEY=ferrite-secret
AWS_REGION=us-east-1

# --- Worker ---
FERRITE_WORK_DIR=/tmp/ferrite-work
FERRITE_MAX_ATTEMPTS=3

# Logging (tracing EnvFilter syntax)
RUST_LOG=info,ferrite_api=debug,ferrite_worker=debug
FERRITE_PLAYBACK_SECRET=change-me-to-a-long-random-secret

# --- Live ingest (SRS) ---
FERRITE_LIVE_RTMP_BASE=rtmp://localhost:1935
FERRITE_LIVE_HLS_BASE=http://localhost:8085
FERRITE_LIVE_API_URL=http://localhost:1985
FERRITE_LIVE_HOOK_SECRET=dev-live-hook-secret
