# Copy to `.env` and adjust as needed. All vars are prefixed FERRITE_.
# Defaults already match the bundled docker-compose stack.

# --- API ---
FERRITE_BIND_ADDR=0.0.0.0:8787
FERRITE_PUBLIC_URL=http://localhost:8787

# --- Postgres ---
FERRITE_DATABASE_URL=postgres://ferrite:ferrite@localhost:5432/ferrite
# API connects as this non-superuser role so Postgres RLS binds (see migration 0017).
# Unset = API uses the owner URL above and RLS is inert (app-layer scoping still applies).
FERRITE_API_DATABASE_URL=postgres://ferrite_app:ferrite_app@localhost:5455/ferrite

# --- Redis (job queue) ---
FERRITE_REDIS_URL=redis://localhost:6379
FERRITE_QUEUE_GROUP=transcoders
FERRITE_MAX_INFLIGHT_PER_TENANT=4
FERRITE_RECLAIM_MIN_IDLE_SECS=30
FERRITE_JOB_STALE_SECS=3600
FERRITE_RUN_SCHEDULER=true
FERRITE_ENCODER=cpu

# --- Object storage (MinIO in dev) ---
FERRITE_S3_BUCKET=ferrite
FERRITE_S3_ENDPOINT_URL=http://localhost:9000
FERRITE_S3_FORCE_PATH_STYLE=true

# AWS SDK credentials (MinIO root creds in dev)
AWS_ACCESS_KEY_ID=ferrite
AWS_SECRET_ACCESS_KEY=ferrite-secret
AWS_REGION=us-east-1

# --- Worker ---
FERRITE_WORK_DIR=/tmp/ferrite-work
FERRITE_MAX_ATTEMPTS=3

# Logging (tracing EnvFilter syntax)
RUST_LOG=info,ferrite_api=debug,ferrite_worker=debug
FERRITE_PLAYBACK_SECRET=change-me-to-a-long-random-secret
FERRITE_AUTH_SECRET=dev-auth-jwt-secret-change-me

# --- Live ingest (SRS) ---
FERRITE_LIVE_RTMP_BASE=rtmp://localhost:1935
FERRITE_LIVE_SRT_BASE=srt://localhost:10080
FERRITE_LIVE_HLS_BASE=http://localhost:8085
FERRITE_LIVE_API_URL=http://localhost:1985
FERRITE_LIVE_HOOK_SECRET=dev-live-hook-secret

# Frontend base URL (for links in emails)
FERRITE_APP_BASE_URL=http://localhost:5173

# Email (SMTP) — optional; unset = emails are logged to the console (dev mode)
# FERRITE_SMTP_HOST=smtp.example.com
# FERRITE_SMTP_PORT=587
# FERRITE_SMTP_USER=apikey
# FERRITE_SMTP_PASSWORD=your-smtp-password
# FERRITE_SMTP_FROM=Ferrite <no-reply@yourdomain.com>

# Auto-captions (worker) — optional; unset = captions skipped
# Local whisper.cpp:
# FERRITE_WHISPER_BIN=/usr/local/bin/whisper-cli
# FERRITE_WHISPER_MODEL=/models/ggml-base.en.bin
# Or any OpenAI-compatible transcription endpoint (provider-agnostic):
# FERRITE_AI_BASE_URL=https://api.openai.com/v1
# FERRITE_AI_KEY=sk-...
# FERRITE_AI_MODEL=whisper-1
# FERRITE_AI_CHAT_MODEL=gpt-4o-mini   # for AI shorts highlight selection (optional; heuristic fallback)

# Content provenance signing key (Ed25519 seed); unset disables provenance
FERRITE_PROVENANCE_SECRET=change-me-provenance-key

# Platform superadmin emails (comma-separated) — cross-tenant admin
# FERRITE_SUPERADMIN_EMAILS=you@example.com
